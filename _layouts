<div class="container mt-5 pt-5">
    <article class="donation-card p-5">
        <h1 class="headline accent-text">{{ page.title }}</h1>
        <p class="pay-label">{{ page.date | date: "%B %d, %Y" }}</p>
        <hr style="border-color: var(--accent-gold);">
        <div class="post-content text-white opacity-75">
            {{ content }}
        </div>
    </article>
</div>
